# ── HELM environment ────────────────────────────────────────────────
# Supabase connection string. Use the POOLED connection (port 6543) for
# serverless/Vercel. Find it in Supabase → Project Settings → Database.
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Strong random secret for signing JWTs.
JWT_SECRET="change-this-to-a-long-random-string"

# Local server port (ignored on Vercel).
PORT=4000

# Set to "disable" only for a local, non-SSL Postgres. Leave unset for Supabase.
# PGSSL=disable

# AI CMO brain (optional) — enables the AI Chief Marketing Officer.
# Without it, the Brain page works but reports "not configured".
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-sonnet-4-6)
ANTHROPIC_MODEL=
